function majorityElement(nums: number[]): number {
    // there are only 2 numbers in the array

    // keep count of candidate
    let count: number = 1;
    let candidate: number = nums[0];

    for (let i = 1; i < nums.length; i++) {
        // if candidate increment count
        if (candidate === nums[i]) {
            count ++;
        } else {
            // decrease count
            count --;
        }

        // when count is 0, keep track of new candidate
        if (count <= 0) {
            candidate = nums[i];
            count = 1;
        }
    }

    return candidate;
};