function judgeCircle(moves: string): boolean {
    let y: number = 0;
    let x: number = 0;

    for (const move of moves) {
        if (move === "U") {
            y += 1;
        } else if (move === "D") {
            y -= 1;
        } else if (move === "R") {
            x += 1;
        } else if (move === "L") {
            x -= 1;
        }

    }

    return x === 0 && y ===0;
};