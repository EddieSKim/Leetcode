function maxArea(height: number[]): number {
    let max: number = 0;

    let left: number = 0;
    let right: number = height.length-1;
    
    while (left != right) {

        let tempMax = 0;
        if (height[left] >= height[right]) {
            tempMax = height[right] * (right - left);
            right--;
        } else {
            tempMax = height[left] * (right - left);
            left++;
        }

        if (tempMax > max) {
            max = tempMax;
        }
    }

    return max;
};