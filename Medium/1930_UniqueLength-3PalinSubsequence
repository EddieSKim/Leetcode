function countPalindromicSubsequence(s: string): number {
    // create a map of each letter with count
    const charArr: string[] = s.split('');
    let result: number = 0;
    const charSet: Set<string> = new Set();


    for (let i = 0 ; i < charArr.length; i++) {
        if (i + 1 === charArr.length - 1) {
            return result;
        }

        if (charSet.has(charArr[i])) {
            continue;
        }
        let left = i + 1;
        let right = charArr.length - 1;
        let unique = new Set();
        let hasSame = false;
        const currChar: string = charArr[i];
        while (right > left) {
            if (charArr[right] !== currChar) {
                right--;
            }

            if (left === right) {
                break;
            }

            if (charArr[right] !== currChar) {
                continue;
            }
            
            if (!unique.has(charArr[left])) {
                unique.add(charArr[left]);
            }
            left++;
        }
        result += unique.size;
        charSet.add(charArr[i]);
    }

    return result;
};