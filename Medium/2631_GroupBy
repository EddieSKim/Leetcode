interface Array<T> {
    groupBy(fn: (item: T) => string): Record<string, T[]>
}


Array.prototype.groupBy = function(fn) {
    const obj = {};
    this.map((item) => {
        if (obj[fn(item)]) {
            obj[fn(item)].push(item);
        } else {
            obj[fn(item)] = [item];
        }
    });

    return obj;
}

/**
 * [1,2,3].groupBy(String) // {"1":[1],"2":[2],"3":[3]}
 */