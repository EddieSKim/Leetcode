function sortVowels(s: string): string {
    let arr = s.split("");
    const vowels: Set<string> = new Set(["a", "e", "i", "o", "u", "A", "E", "I", "O","U"]);

    const allVowels = arr.filter((char) => vowels.has(char));
    allVowels.sort();

    let vIndex = 0;
    for (let i = 0; i < arr.length; i++) {
        if (vowels.has(arr[i])) {
            arr[i] = allVowels[vIndex];
            vIndex++;
        }
    }

    return arr.join("");
};