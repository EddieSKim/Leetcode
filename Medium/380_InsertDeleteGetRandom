class RandomizedSet {
    #arr;
    constructor() {
        this.#arr = [];
    }

    insert(val: number): boolean {
        if (!this.#arr.includes(val)) {
            this.#arr.push(val);
            return true;
        }
        return false;
    }

    remove(val: number): boolean {
        if (!this.#arr.includes(val)) {
            return false;
        }

        const index = this.#arr.indexOf(val);
        this.#arr.splice(index, index + 1);
        return true;
    }

    getRandom(): number {
        return this.#arr[Math.floor(Math.random() * (this.#arr.length -  1))];
    }
}

