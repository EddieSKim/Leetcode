class Solution {
    public List<List<String>> groupAnagrams(String[] strs) {
        List<List<String>> result = new ArrayList<>();
        HashMap<String, List<String>> strMap = new HashMap<>();

        for (int i = 0 ; i < strs.length; i++) {
            String sortedStr = sortString(strs[i]);

            strMap.putIfAbsent(sortedStr, new ArrayList<>());
            strMap.get(sortedStr).add(strs[i]);  
        }

        for (List<String> value : strMap.values()) {
            result.add(value);
        }

        return result;
    }

    private String sortString(String value) {
        char[] chars = value.toCharArray();
        java.util.Arrays.sort(chars);
        return new String(chars);
    }
}